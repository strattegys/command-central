{
  "providers": {
    "gemini": {
      "apiKey": "${GEMINI_API_KEY}"
    },
    "groq": {
      "apiKey": "${GROQ_API_KEY}"
    }
  },
  "agents": {
    "defaults": {
      "model": "gemini/gemini-2.5-flash",
      "maxTokens": 4096,
      "temperature": 0.7,
      "maxToolIterations": 20,
      "memoryWindow": 50,
      "workspace": "/app/workspace"
    }
  },
  "tools": {
    "web": {
      "search": {
        "apiKey": "${BRAVE_SEARCH_API_KEY}",
        "maxResults": 5
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": ["*"]
    }
  }
}

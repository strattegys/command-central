# === LLM Providers ===
# Gemini (primary) - Get from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (backup) - Get from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# === Channels ===
# Telegram Bot Token - Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# === CRM ===
# Twenty CRM API Key
TWENTY_CRM_API_KEY=your_twenty_crm_api_key_here

# Twenty CRM Base URL (default: http://localhost:3000)
TWENTY_CRM_URL=http://localhost:3000

# === LinkedIn (ConnectSafely) ===
# ConnectSafely API Key
CONNECTSAFELY_API_KEY=your_connectsafely_api_key_here

# ConnectSafely Account ID
CONNECTSAFELY_ACCOUNT_ID=your_account_id_here

# === Web Search ===
# Brave Search API Key - Get from: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

server {
    listen 80;
    server_name tim-bot.b2bcontentartist.com;

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }
}

# After placing this file, run:
#   sudo ln -sf /etc/nginx/sites-available/tim-bot /etc/nginx/sites-enabled/tim-bot
#   sudo nginx -t
#   sudo systemctl reload nginx
#
# Then add SSL with Let's Encrypt:
#   sudo apt install certbot python3-certbot-nginx
#   sudo certbot --nginx -d tim-bot.b2bcontentartist.com

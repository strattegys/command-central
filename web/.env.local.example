# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3001
# Auth.js v5 also reads AUTH_SECRET and AUTH_URL (same values as above).
# Production behind Caddy: set NEXTAUTH_URL or AUTH_URL to the public https origin (e.g. https://command.example.com)
# so cookies and host checks work. docker-compose uses env_file: web/.env.local — include these there.

# Whitelisted email - only this account can log in
ALLOWED_EMAIL=your@email.com

# Groq — agent chat (agent-registry), TTS voice summarization, agent card summaries, CRM artifact chat, etc.
GROQ_API_KEY=your_groq_api_key
# Optional: override model for every Groq-backed agent (docker-compose.dev.yml sets openai/gpt-oss-120b).
# Production: omit to use agent-registry defaults (llama-3.3-70b-versatile).
# GROQ_CHAT_MODEL=openai/gpt-oss-120b

# Gemini — vector memory embeddings for Suzi (pgvector 768); also optional /api/chat/stream fallback if an agent omits provider: "groq"
GEMINI_API_KEY=your_gemini_api_key

# Anthropic API — optional unless you use article_builder / agents with provider "anthropic"
ANTHROPIC_API_KEY=your_anthropic_api_key
# article_builder: tries structured JSON (output_config) on primary + fallback, then legacy Opus without schema.
# Defaults: claude-opus-4-6 → claude-opus-4-5-20251101 → claude-opus-4-20250514
# ANTHROPIC_ARTICLE_MODEL=claude-opus-4-6
# ANTHROPIC_ARTICLE_STRUCTURED_FALLBACK_MODEL=claude-opus-4-5-20251101
# ANTHROPIC_ARTICLE_LEGACY_FALLBACK_MODEL=claude-opus-4-20250514

# Inworld TTS — required for read-aloud (same as Rainbow Bot: rainbow/avabot_server.py)
# Use the SAME INWORLD_TTS_KEY value as on the Project Server Rainbow container.
# Agent registry: Suzi → Olivia, Tim → Timothy, Ghost → Avery (see web/lib/agent-registry.ts ttsVoice).
INWORLD_TTS_KEY=
# Optional global fallback for /api/tts when registry has no ttsVoice; Suzi uses registry Olivia — set this to the same on the droplet for parity.
INWORLD_VOICE_ID=Olivia

# Suzi local testing — chat + memory under web/.dev-ephemeral-chat/suzi/ (gitignored), no vector RAG, no session consolidation
# CHAT_EPHEMERAL_AGENTS=suzi

# Session files, memory dirs, and system prompts use paths like /root/.suzibot/... in the registry.
# Set AGENT_ROOT to the folder that contains .suzibot, .nanobot, .fridaybot, etc. (same layout as /root on the bot host).
# Production Docker: web/Dockerfile sets AGENT_ROOT=/agents and copies repo agents/ → /agents (see docker-compose.yml).
# Local Node dev: point at your checkout, e.g. AGENT_ROOT=C:\path\to\COMMAND-CENTRAL\agents
# AGENT_ROOT=

# Suzi Intake — inbound email (Postmark/Mailgun/etc. POSTs JSON or form fields to this app; no mail server). Webhook path: /api/webhooks/intake-inbound
# Verify with ?secret=…, path /api/webhooks/intake-inbound/<secret> (recommended for Postmark), header x-intake-inbound-secret, or Authorization: Bearer …
# INTAKE_INBOUND_WEBHOOK_SECRET=
# Comma-separated allowed From addresses (parsed email must match exactly, case-insensitive).
# INTAKE_INBOUND_ALLOWED_FROM=you@yourdomain.com

# Internal middleware bypass — required for Unipile webhook → warm-outreach auto “Replied” (server calls /api/crm/human-tasks/resolve without a browser session). Production droplet: set this in web/.env.local (see scripts/patch-server-internal-api-key.mjs).
INTERNAL_API_KEY=
# Optional: override loopback self-fetch (defaults to http://127.0.0.1:$PORT). Multi-node / unusual routing only.
# Also used by warm-outreach cron to POST /api/crm/human-tasks/resolve when MESSAGED follow-up is due.
# APP_INTERNAL_URL=http://127.0.0.1:3001

# Optional: Twenty GraphQL tools / heartbeat (leave unset if unused)
TWENTY_CRM_API_KEY=your_twenty_crm_api_key
TWENTY_CRM_URL=http://localhost:3000

# CRM PostgreSQL — Kanban, workflow builder, human-tasks, packages (Command Central’s own data)
# Status rail "Data platform" probes this when CRM_DB_PASSWORD is set (not TWENTY_CRM_URL).
# Without CRM_DB_PASSWORD the app uses .dev-store/ (empty fake data) — boards will not show real pipelines.
#
# ── Production Docker (droplet) ──
# docker-compose.yml runs service `crm-db` on the same compose network as `web` and sets
# CRM_DB_HOST=crm-db + CRM_DB_PORT=5432 on the web container (overrides these lines for host/port).
# You still MUST set CRM_DB_PASSWORD (and CRM_DB_NAME / CRM_DB_USER if not default) here — compose
# passes the same values to Postgres on first boot. Always deploy with:
#   docker compose --env-file web/.env.local -f docker-compose.yml up -d
# One-time copy from an old Postgres container (e.g. twenty-db-1): scripts/migrate-crm-postgres-from-legacy-container.sh
CRM_DB_HOST=host.docker.internal
# Production (docker-compose.yml web→crm-db): use 5432. Docker dev compose overrides to 5433 — see below.
CRM_DB_PORT=5432
CRM_DB_NAME=default
CRM_DB_USER=postgres
CRM_DB_PASSWORD=your_postgres_password
#
# ── Local dev: Docker (docker-compose.dev.yml) ──
# Compose forces CRM_DB_HOST=host.docker.internal AND CRM_DB_PORT=5433 (tunnel default).
# Start scripts/crm-db-tunnel.ps1 or .sh first (forwards your machine :5433 → droplet localhost:5432).
# On the droplet, crm-db must publish 127.0.0.1:5432 (see docker-compose.yml) or the tunnel has no target.

# Tailscale (optional): On the CC droplet run tools/expose-crm-db-tailscale.sh so Postgres is on
# <droplet 100.x>:5432. Native Node dev can set CRM_DB_HOST to that IP and CRM_DB_PORT=5432 (no tunnel).
# Docker dev still uses the SSH tunnel + host.docker.internal:5433; set CRM_SSH_HOST to 100.x for SSH.
#
# Tunnel binds 0.0.0.0:5433 by default so Docker Desktop can reach Postgres via host.docker.internal.
# Loopback-only: set CRM_TUNNEL_BIND=127.0.0.1 before running the tunnel script.
# From your PC (tunnel running):  cd web && npm run check-crm-db
# Agent vector RAG uses pgvector in crm-db (image pgvector/pgvector:pg16 + migrate-vector-memory.sql). check-crm-db verifies extension + _memory.
# Do NOT use CRM_DB_HOST=127.0.0.1 in .env.local for Docker — inside the container that is wrong.
#
# ── Local dev: Node on the host only (npm run dev, no Docker) ──
# Then CRM_DB_HOST=127.0.0.1 and CRM_DB_PORT=5433 (or 5432) is correct with the same tunnel.
#
# Optional: single URL instead of CRM_DB_* (db-exec.mjs and some tools)
# DATABASE_URL=postgresql://postgres:PASSWORD@127.0.0.1:5432/default
#
# Optional: override workspace schema for db-exec.mjs (default matches lib/db.ts)
# CRM_DB_SEARCH_PATH=workspace_9rc10n79wgdr0r3z6mzti24f6
#
# Run SQL from repo root (loads .env.local automatically):
#   cd web && npm run db:exec -- scripts/seed-vibe-coding-warm-outreach-package.sql
#   cd web && npm run db:exec -- -e "SELECT id, name FROM \"_package\" LIMIT 3"

# LinkedIn (ConnectSafely) - optional
CONNECTSAFELY_API_KEY=your_connectsafely_api_key
CONNECTSAFELY_ACCOUNT_ID=your_account_id

# LinkedIn via Unipile — warm-outreach RESEARCHING enrichment + /api/webhooks/unipile
# DSN is host:port from the Unipile dashboard (e.g. api32.unipile.com:16299). No https:// prefix.
UNIPILE_API_KEY=
UNIPILE_DSN=api32.unipile.com:16299
UNIPILE_ACCOUNT_ID=
# Optional: Unipile dashboard → webhook auth header unipile-auth. Also allows POST /api/crm/human-tasks/resolve with Authorization: Bearer <this> if INTERNAL_API_KEY is unset (see middleware.ts).
UNIPILE_WEBHOOK_SECRET=

# Web Search (Brave) - optional
BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# Path to tool scripts
TOOL_SCRIPTS_PATH=/root/.nanobot/tools

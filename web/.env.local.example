# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3001

# Whitelisted email - only this account can log in
ALLOWED_EMAIL=your@email.com

# Gemini API (primary chat + embeddings for most agents)
GEMINI_API_KEY=your_gemini_api_key

# Anthropic (memory consolidation, article workflows, some tools)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Groq (Suzi, artifact chat, optional agents)
GROQ_API_KEY=your_groq_api_key

# Kokoro TTS (self-hosted on Project Server — see PROJECT-MEMORY)
KOKORO_TTS_URL=https://tts.b2bcontentartist.com/tts
KOKORO_VOICE=af_sky
TTS_API_KEY=shared_secret_with_caddy

# Internal middleware bypass (optional)
INTERNAL_API_KEY=

# Twenty CRM (GraphQL / tools)
TWENTY_CRM_API_KEY=your_twenty_crm_api_key
TWENTY_CRM_URL=http://localhost:3000

# CRM PostgreSQL — Kanban, workflow builder, human-tasks, packages (same DB Twenty uses)
# Without CRM_DB_PASSWORD the app uses .dev-store/ (empty fake data) — boards will not show real pipelines.
#
# ── Production Docker (Command Central on the droplet) ──
# docker-compose.yml adds host.docker.internal → host gateway. Point the web container at Postgres on the host:
CRM_DB_HOST=host.docker.internal
CRM_DB_PORT=5432
CRM_DB_NAME=default
CRM_DB_USER=postgres
CRM_DB_PASSWORD=your_postgres_password
#
# ── Local dev on Windows (Docker dev compose) ──
# docker-compose.dev.yml already sets CRM_DB_HOST=host.docker.internal. Typical tunnel to droplet CRM:
#   ssh -L 5433:localhost:5432 root@137.184.187.233
# Then use CRM_DB_PORT=5433 (and keep the tunnel open).
#
# ── Local Node (no Docker) ──
# CRM_DB_HOST=127.0.0.1 and CRM_DB_PORT=5432 or 5433 as appropriate.

# LinkedIn (ConnectSafely) - optional
CONNECTSAFELY_API_KEY=your_connectsafely_api_key
CONNECTSAFELY_ACCOUNT_ID=your_account_id

# Web Search (Brave) - optional
BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# Path to tool scripts
TOOL_SCRIPTS_PATH=/root/.nanobot/tools

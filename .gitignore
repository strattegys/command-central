# Environment files with secrets
.env
*.env.local
config.json

# API Keys and sensitive data
**/config.json
**/*_API_KEY*
**/*TOKEN*
**/*SECRET*

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# Claude Code local overrides (permissions history; do not commit)
.claude/settings.local.json

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Backup files
*.backup
*.backup2
*.bak
*.tar.gz

# Temporary files
tmp/
temp/

# Node
node_modules/
.next/

# Python
*.pyc
__pycache__/
.venv/

# NanoClaw legacy (deprecated)
nanoclaw/
**/nanoclaw/**

# Docker bind-mount: uploaded agent photos (keep folder in git via .gitkeep)
docker-data/agent-avatars/*
!docker-data/agent-avatars/.gitkeep

# Local dev: session JSONL / memory under agents/ (do not commit; prod uses host bind mount)
agents/.*/
